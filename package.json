{
    "name": "blackmind",
    "version": "1.0.0",
    "main": "electron/main.js",
    "packageManager": "pnpm@9.15.0",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    },
    "scripts": {
    "dev": "vite --port 3000",
    "dev:desktop": "concurrently -k \"npm:dev\" \"npm:dev:electron\" \"pnpm --dir ../.. run dev:channels\"",
    "dev:electron": "wait-on tcp:3000 && VITE_DEV_SERVER_URL=http://127.0.0.1:3000 electron .",
    "dev:electron:mcp": "BLACKMIND_ENABLE_INTERNAL_MCP=1 wait-on tcp:3000 && VITE_DEV_SERVER_URL=http://127.0.0.1:3000 electron .",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "mcp:bridge": "node electron/mcp-bridge.js",
    "mcp:stdio": "BLACKMIND_ENABLE_INTERNAL_MCP=1 electron .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@tailwindcss/postcss": "^4.2.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/jest": "^29.5.14",
        "@types/node": "^25.2.2",
        "@types/react": "^19.2.13",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.3",
        "autoprefixer": "^10.4.24",
        "babel-jest": "^30.3.0",
        "concurrently": "^9.2.1",
        "electron": "^41.0.0",
        "fast-check": "^3.15.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.3.0",
        "path-browserify": "^1.0.1",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^0.19.8",
        "wait-on": "^9.0.4"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@radix-ui/react-tabs": "^1.1.13",
        "@tsparticles/engine": "^3.9.1",
        "@tsparticles/react": "^3.0.0",
        "@tsparticles/slim": "^3.9.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.563.0",
        "motion": "^12.35.1",
        "radix-ui": "^1.4.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwind-merge": "^3.4.0",
        "tailwindcss-animate": "^1.0.7",
        "three": "^0.183.2"
    }
}
