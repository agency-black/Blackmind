# Black Server - Configuración para blackmind
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=qdrant-local-key-2026
VECTOR_COLLECTION=blackmind_docs
VECTOR_SIZE=768

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_TIMEOUT_MS=30000

# HTTP Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_BODY_SIZE=1mb

# Chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
